---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Classes', href: '/classes' },
  { label: 'Schedule', href: '/schedule' },
  { label: 'Membership', href: '/membership' },
  { label: 'Contact', href: '/contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-zinc-900 border-t border-zinc-800" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        
        <a  href="/"
          class="flex items-center gap-2 group focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900 rounded-md"
          aria-label="Summit Fitness & CrossFit - Home"
        >
          <div class="relative w-10 h-10 flex items-center justify-center" aria-hidden="true">
            <svg
              class="w-10 h-10 text-orange-600 transition-transform duration-300 group-hover:scale-110"
              viewBox="0 0 40 40"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M20 4L4 36H36L20 4Z" fill="currentColor" />
              <path d="M20 14L12 30H28L20 14Z" fill="#18181b" />
              <path d="M20 20C20 20 16 26 16 28C16 30.2 17.8 32 20 32C22.2 32 24 30.2 24 28C24 26 20 20 20 20Z" fill="#f97316" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-display text-xl font-bold text-white tracking-tight leading-tight">
              SUMMIT
            </span>
            <span class="text-xs font-semibold text-orange-500 uppercase tracking-widest">
              Fitness & CrossFit
            </span>
          </div>
        </a>
        <p class="mt-4 text-zinc-400 text-sm leading-relaxed">
          Push your limits. Reach your summit. Join our community of athletes dedicated to strength, endurance, and transformation.
        </p>

        <!-- Social Links -->
        <div class="mt-6 flex items-center gap-3">
          
          <a  href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Follow us on Facebook (opens in new tab)"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
            </svg>
          </a>
          
          <a  href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Follow us on Instagram (opens in new tab)"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
          
          <a  href="https://youtube.com"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label="Follow us on YouTube (opens in new tab)"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <nav class="lg:col-span-1" aria-label="Footer navigation">
        <h2 class="font-display text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Quick Links
        </h2>
        <ul class="space-y-3" role="list">
          {navLinks.map((link) => (
            <li>
              
              <a  href={link.href}
                class="text-zinc-400 hover:text-orange-500 focus:outline-none focus-visible:text-orange-500 transition-colors duration-200 rounded"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact Info -->
      <div class="lg:col-span-1">
        <h2 class="font-display text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Contact Us
        </h2>
        <address class="not-italic space-y-3 text-zinc-400">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-orange-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>123 Fitness Way<br />Littleton, NH 03561</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+15551234567" class="hover:text-orange-500 focus:outline-none focus-visible:text-orange-500 transition-colors">
              (555) 123-4567
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@summitfitness.com" class="hover:text-orange-500 focus:outline-none focus-visible:text-orange-500 transition-colors">
              info@summitfitness.com
            </a>
          </div>
        </address>
      </div>

      <!-- Hours -->
      <div class="lg:col-span-1">
        <h2 class="font-display text-sm font-semibold text-white uppercase tracking-wider mb-4">
          Hours
        </h2>
        <dl class="space-y-2 text-zinc-400 text-sm">
          <div class="flex gap-2">
            <dt class="font-medium text-white">Mon–Fri:</dt>
            <dd>5:00 AM – 10:00 PM</dd>
          </div>
          <div class="flex gap-2">
            <dt class="font-medium text-white">Sat–Sun:</dt>
            <dd>7:00 AM – 8:00 PM</dd>
          </div>
        </dl>
        <div class="mt-6">
          <a href="/membership" class="btn-primary w-full text-center block">
            Join Now
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar — fixed: text-zinc-500 → text-zinc-400 -->
    <div class="mt-12 pt-8 border-t border-zinc-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-zinc-400 text-sm">
        &copy; {currentYear} Summit Fitness & CrossFit. All rights reserved.
      </p>
      <div class="flex items-center gap-6 text-sm">
        <a href="/privacy" class="text-zinc-400 hover:text-orange-500 focus:outline-none focus-visible:text-orange-500 transition-colors rounded">
          Privacy Policy
        </a>
        <a href="/terms" class="text-zinc-400 hover:text-orange-500 focus:outline-none focus-visible:text-orange-500 transition-colors rounded">
          Terms of Service
        </a>
        <a href="/accessibility" class="text-zinc-400 hover:text-orange-500 focus:outline-none focus-visible:text-orange-500 transition-colors rounded">
          Accessibility
        </a>
      </div>
    </div>
  </div>
</footer>