---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms of Service | Summit Fitness & CrossFit"
  description="Terms of Service for Summit Fitness & CrossFit. Please read these terms carefully before using our services."
>
  <section class="py-20 md:py-28 bg-zinc-950" aria-labelledby="hero-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
        <h1 id="hero-heading" class="font-display text-4xl md:text-5xl font-bold uppercase tracking-tight">
          Terms of Service
        </h1>
      </div>
      <p class="text-zinc-400 mb-12">Last updated: January 1, 2025</p>

      <div class="prose prose-invert max-w-none space-y-10 text-zinc-300 leading-relaxed">

        <section aria-labelledby="agreement-heading">
          <h2 id="agreement-heading" class="font-display text-2xl font-bold uppercase tracking-tight text-white mb-4">Agreement to Terms</h2>
          <p>By accessing our website or becoming a member of Summit Fitness & CrossFit, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services.</p>
        </section>

        <section aria-labelledby="membership-heading">
          <h2 id="membership-heading" class="font-display text-2xl font-bold uppercase tracking-tight text-white mb-4">Membership Terms</h2>
          <ul class="list-disc list-inside space-y-2 mt-4 text-zinc-400">
            <li>All memberships are month-to-month with no long-term contract required</li>
            <li>Cancellation requires 30 days written notice</li>
            <li>Membership fees are billed on the same date each month</li>
            <li>Members must be at least 16 years of age</li>
            <li>Members aged 16-17 require a parent or guardian waiver</li>
          </ul>
        </section>

        <section aria-labelledby="conduct-heading">
          <h2 id="conduct-heading" class="font-display text-2xl font-bold uppercase tracking-tight text-white mb-4">Code of Conduct</h2>
          <p>All members agree to:</p>
          <ul class="list-disc list-inside space-y-2 mt-4 text-zinc-400">
            <li>Treat fellow members, coaches, and staff with respect</li>
            <li>Follow all safety guidelines and coach instructions</li>
            <li>Return equipment to its proper place after use</li>
            <li>Report any injuries or equipment issues to staff immediately</li>
            <li>Not engage in harassment, bullying, or discriminatory behavior</li>
          </ul>
        </section>

        <section aria-labelledby="liability-heading">
          <h2 id="liability-heading" class="font-display text-2xl font-bold uppercase tracking-tight text-white mb-4">Liability Waiver</h2>
          <p>Physical activity involves inherent risks. By participating in classes and using our facility, you acknowledge these risks and agree that Summit Fitness & CrossFit is not liable for injuries sustained during normal participation in fitness activities. All members are required to sign a separate liability waiver upon enrollment.</p>
        </section>

        <section aria-labelledby="changes-heading">
          <h2 id="changes-heading" class="font-display text-2xl font-bold uppercase tracking-tight text-white mb-4">Changes to Terms</h2>
          <p>We reserve the right to modify these terms at any time. Members will be notified of significant changes via email. Continued use of our services after changes constitutes acceptance of the updated terms.</p>
        </section>

        <section aria-labelledby="contact-heading">
          <h2 id="contact-heading" class="font-display text-2xl font-bold uppercase tracking-tight text-white mb-4">Contact Us</h2>
          <p>If you have questions about these Terms of Service, please contact us at:</p>
          <address class="not-italic mt-4 text-zinc-400">
            Summit Fitness & CrossFit<br />
            123 Fitness Way, Littleton, NH 03561<br />
            <a href="tel:+15551234567" class="text-orange-500 hover:underline">(555) 123-4567</a><br />
            <a href="mailto:info@summitfitness.com" class="text-orange-500 hover:underline">info@summitfitness.com</a>
          </address>
        </section>

      </div>
    </div>
  </section>
</Layout>