---
import Layout from '../layouts/Layout.astro';

const subjects = [
  { value: '', label: 'Select a subject' },
  { value: 'general', label: 'General Inquiry' },
  { value: 'membership', label: 'Membership Question' },
  { value: 'trial', label: 'Free Trial Request' },
  { value: 'dropin', label: 'Drop-In Visit' },
  { value: 'corporate', label: 'Corporate/Group Training' },
  { value: 'other', label: 'Other' }
];
---

<Layout
  title="Contact Us | Summit Fitness & CrossFit"
  description="Get in touch with Summit Fitness & CrossFit. Contact us for membership inquiries, schedule a free trial, or visit our facility in Littleton, NH."
>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 bg-zinc-900" aria-labelledby="hero-heading">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-orange-600/10 to-transparent"></div>
      <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-600/30 to-transparent"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1 id="hero-heading" class="font-display text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-tight mb-6">
          Contact <span class="text-orange-500">Us</span>
        </h1>
        <p class="text-lg md:text-xl text-zinc-300 leading-relaxed">
          Ready to start your fitness journey? Have questions about membership or classes?
          We'd love to hear from you. Reach out and our team will get back to you within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form & Info -->
  <section class="py-16 md:py-24 bg-zinc-950" aria-labelledby="contact-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="contact-heading" class="sr-only">Contact Information and Form</h2>

      <div class="grid gap-12 lg:grid-cols-2 max-w-6xl mx-auto">
        <!-- Contact Form -->
        <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6 md:p-8">
          <h3 id="form-heading" class="font-display text-2xl font-bold uppercase tracking-tight mb-2">
            Send Us a Message
          </h3>
          <p class="text-zinc-400 mb-8">Fill out the form below and we'll get back to you as soon as possible.</p>

          <form action="/api/contact" method="POST" class="space-y-6" aria-labelledby="form-heading">
            <!-- Full Name -->
            <div>
              <label for="fullName" class="block text-sm font-semibold uppercase tracking-wide text-zinc-300 mb-2">
                Full Name <span class="text-orange-500" aria-hidden="true">*</span>
              </label>
              <input
                type="text" id="fullName" name="fullName"
                required aria-required="true" autocomplete="name"
                class="w-full px-4 py-3 bg-zinc-950 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 transition-colors duration-200 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20"
                placeholder="John Doe"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-semibold uppercase tracking-wide text-zinc-300 mb-2">
                Email Address <span class="text-orange-500" aria-hidden="true">*</span>
              </label>
              <input
                type="email" id="email" name="email"
                required aria-required="true" autocomplete="email"
                class="w-full px-4 py-3 bg-zinc-950 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 transition-colors duration-200 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20"
                placeholder="john@example.com"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block text-sm font-semibold uppercase tracking-wide text-zinc-300 mb-2">
                Phone Number
              </label>
              <input
                type="tel" id="phone" name="phone"
                autocomplete="tel" aria-describedby="phone-hint"
                class="w-full px-4 py-3 bg-zinc-950 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 transition-colors duration-200 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20"
                placeholder="(555) 123-4567"
              />
              <p id="phone-hint" class="mt-1 text-sm text-zinc-500">Optional — we'll only call if you request it</p>
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block text-sm font-semibold uppercase tracking-wide text-zinc-300 mb-2">
                Subject <span class="text-orange-500" aria-hidden="true">*</span>
              </label>
              <select
                id="subject" name="subject"
                required aria-required="true"
                class="w-full px-4 py-3 bg-zinc-950 border border-zinc-700 rounded-lg text-white transition-colors duration-200 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20"
              >
                {subjects.map((subject) => (
                  <option value={subject.value} disabled={subject.value === ''} selected={subject.value === ''}>
                    {subject.label}
                  </option>
                ))}
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-semibold uppercase tracking-wide text-zinc-300 mb-2">
                Message <span class="text-orange-500" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message" name="message" rows="5"
                required aria-required="true" aria-describedby="message-hint"
                class="w-full px-4 py-3 bg-zinc-950 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 transition-colors duration-200 focus:outline-none focus:border-orange-500 focus:ring-2 focus:ring-orange-500/20 resize-y"
                placeholder="Tell us about your fitness goals or ask us anything..."
              ></textarea>
              <p id="message-hint" class="mt-1 text-sm text-zinc-500">Minimum 20 characters</p>
            </div>

            <!-- Required note -->
            <p class="text-sm text-zinc-500">
              <span class="text-orange-500" aria-hidden="true">*</span> Required fields
            </p>

            <button
              type="submit"
              class="w-full btn-primary text-lg"
            >
              Send Message
            </button>

            <p class="text-sm text-zinc-500 text-center">
              By submitting this form, you agree to our
              <a href="/privacy" class="text-orange-500 hover:underline focus:outline-none focus-visible:underline">Privacy Policy</a>.
            </p>
          </form>
        </div>

        <!-- Contact Info & Map -->
        <div class="space-y-8">
          <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6 md:p-8" aria-labelledby="info-heading">
            <h3 id="info-heading" class="font-display text-2xl font-bold uppercase tracking-tight mb-6">Get In Touch</h3>

            <div class="space-y-6">
              <!-- Address -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-orange-600/10 rounded-lg flex items-center justify-center" aria-hidden="true">
                  <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-white mb-1">Address</h4>
                  <address class="text-zinc-400 not-italic leading-relaxed">
                    123 Fitness Way, Suite 100<br />
                    Littleton, NH 03561
                  </address>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-orange-600/10 rounded-lg flex items-center justify-center" aria-hidden="true">
                  <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-white mb-1">Phone</h4>
                  <a href="tel:+15551234567" class="text-zinc-400 hover:text-orange-500 transition-colors focus:outline-none focus-visible:text-orange-500 focus-visible:underline">(555) 123-4567</a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-orange-600/10 rounded-lg flex items-center justify-center" aria-hidden="true">
                  <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-white mb-1">Email</h4>
                  <a href="mailto:info@summitfitness.com" class="text-zinc-400 hover:text-orange-500 transition-colors focus:outline-none focus-visible:text-orange-500 focus-visible:underline">info@summitfitness.com</a>
                </div>
              </div>

              <!-- Hours -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-orange-600/10 rounded-lg flex items-center justify-center" aria-hidden="true">
                  <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-white mb-1">Hours of Operation</h4>
                  <dl class="text-zinc-400 space-y-1">
                    <div class="flex gap-2"><dt class="font-medium">Mon–Fri:</dt><dd>5:00 AM – 10:00 PM</dd></div>
                    <div class="flex gap-2"><dt class="font-medium">Sat–Sun:</dt><dd>7:00 AM – 8:00 PM</dd></div>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div class="bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden" aria-labelledby="map-heading">
            <div class="p-4 border-b border-zinc-800">
              <h3 id="map-heading" class="font-display text-lg font-bold uppercase tracking-tight">Find Us</h3>
            </div>
            <div
              class="aspect-video bg-zinc-950 flex items-center justify-center"
              role="img"
              aria-label="Map showing Summit Fitness & CrossFit location at 123 Fitness Way, Littleton, NH 03561"
            >
              <div class="text-center p-6">
                <div class="w-16 h-16 bg-orange-600/20 rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
                  <svg class="w-8 h-8 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <p class="text-zinc-400 text-sm">Google Maps Embed Placeholder</p>
                <a
                  href="https://maps.google.com/?q=Littleton+NH"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 mt-3 text-orange-500 hover:underline focus:outline-none focus-visible:underline"
                >
                  Open in Google Maps
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
              <!--
                Replace placeholder with:
                <iframe
                  src="https://www.google.com/maps/embed?pb=YOUR_EMBED_URL"
                  width="100%" height="100%"
                  style="border:0;" allowfullscreen="" loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Summit Fitness & CrossFit location"
                ></iframe>
              -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Follow Us -->
  <section class="py-16 md:py-20 bg-zinc-900" aria-labelledby="social-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <div class="flex items-center justify-center gap-4 mb-4">
          <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
          <h2 id="social-heading" class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">Follow Us</h2>
          <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
        </div>
        <p class="text-zinc-400 mb-8">Stay connected with the Summit community for workout tips, member spotlights, and daily motivation.</p>

        <ul class="flex justify-center gap-6" role="list">
          <li>
            <a
              href="https://facebook.com"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-center w-14 h-14 bg-zinc-950 border border-zinc-800 rounded-xl transition-all duration-200 hover:bg-orange-600 hover:border-orange-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900"
              aria-label="Follow us on Facebook (opens in new tab)"
            >
              <svg class="w-6 h-6 text-zinc-400 transition-colors group-hover:text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
              </svg>
            </a>
          </li>
          <li>
            <a
              href="https://instagram.com"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-center w-14 h-14 bg-zinc-950 border border-zinc-800 rounded-xl transition-all duration-200 hover:bg-orange-600 hover:border-orange-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900"
              aria-label="Follow us on Instagram (opens in new tab)"
            >
              <svg class="w-6 h-6 text-zinc-400 transition-colors group-hover:text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
            </a>
          </li>
          <li>
            <a
              href="https://youtube.com"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-center w-14 h-14 bg-zinc-950 border border-zinc-800 rounded-xl transition-all duration-200 hover:bg-orange-600 hover:border-orange-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900"
              aria-label="Follow us on YouTube (opens in new tab)"
            >
              <svg class="w-6 h-6 text-zinc-400 transition-colors group-hover:text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" />
              </svg>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-zinc-950 relative overflow-hidden" aria-labelledby="cta-heading">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-64 h-64 bg-orange-600/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-orange-600/5 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h2 id="cta-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-tight mb-6">
          Ready to Get <span class="text-orange-500">Started?</span>
        </h2>
        <p class="text-lg text-zinc-300 mb-8 leading-relaxed">
          Don't wait another day to start your fitness journey. Book your free trial class and experience Summit firsthand.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/schedule" class="btn-primary text-lg">View Class Schedule</a>
          <a
            href="/membership"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-orange-600 text-orange-500 font-bold uppercase tracking-wide rounded transition-all duration-200 hover:bg-orange-600 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
          >
            Explore Memberships
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>