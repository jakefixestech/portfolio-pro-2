---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search | Summit Fitness & CrossFit" description="Search Summit Fitness & CrossFit for classes, schedules, membership and more.">

  <!-- Hero Banner -->
  <section style="position:relative;overflow:hidden;background:#09090b;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(234,88,12,0.15) 0%,transparent 70%);z-index:0;"></div>
    <div style="max-width:56rem;margin:0 auto;padding:4rem 1.5rem 7rem 1.5rem;text-align:center;position:relative;z-index:2;">
      <p style="font-size:0.875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#f97316;">Search</p>
      <h1 style="margin-top:0.5rem;font-size:2.5rem;font-weight:800;color:white;line-height:1.2;text-transform:uppercase;letter-spacing:0.02em;">What Are You Looking For?</h1>
      <div style="margin-top:1.5rem;max-width:36rem;margin-left:auto;margin-right:auto;">
        <form action="/search" method="get" role="search" style="display:flex;gap:0.5rem;">
          <input
            type="search"
            id="hero-search"
            name="q"
            placeholder="Search classes, schedule, membership..."
            autocomplete="off"
            style="flex:1;padding:0.875rem 1.25rem;border:1px solid #3f3f46;border-radius:0.5rem;font-size:1rem;color:white;background:#18181b;min-width:0;"
            aria-label="Search Summit Fitness & CrossFit"
          />
          <!-- Fixed: background #ea580c → #c2410c for WCAG AA contrast -->
          <button type="submit" style="display:inline-flex;align-items:center;gap:0.5rem;background:#c2410c;color:white;font-weight:700;padding:0.875rem 1.5rem;border-radius:0.5rem;border:none;cursor:pointer;font-size:1rem;white-space:nowrap;text-transform:uppercase;letter-spacing:0.05em;">
            <svg style="height:1.1rem;width:1.1rem;" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            Search
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section style="background:#09090b;padding:3rem 1.5rem 5rem 1.5rem;min-height:60vh;border-top:1px solid #27272a;">
    <div style="max-width:56rem;margin:0 auto;">

      <div id="search-status" style="margin-bottom:1.5rem;min-height:1.5rem;"></div>
      <div id="search-results-list" aria-live="polite" aria-label="Search results"></div>

      <!-- Quick Links (shown when no search) -->
      <div id="quick-links">
        <p style="font-size:0.875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#f97316;margin-bottom:1rem;">Quick Links</p>
        <div id="quick-grid">
          <a href="/classes" class="quick-card">
            <div class="quick-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            </div>
            <div>
              <div class="quick-title">Classes</div>
              <div class="quick-desc">CrossFit, strength training, cardio and more</div>
            </div>
          </a>
          <a href="/schedule" class="quick-card">
            <div class="quick-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <div class="quick-title">Schedule</div>
              <div class="quick-desc">View our weekly class schedule</div>
            </div>
          </a>
          <a href="/membership" class="quick-card">
            <div class="quick-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
            </div>
            <div>
              <div class="quick-title">Membership</div>
              <div class="quick-desc">Plans and pricing for every goal</div>
            </div>
          </a>
          <a href="/about" class="quick-card">
            <div class="quick-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <div class="quick-title">About Us</div>
              <div class="quick-desc">Our coaches, facility and mission</div>
            </div>
          </a>
          <a href="/contact" class="quick-card">
            <div class="quick-icon" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="quick-title">Contact</div>
              <div class="quick-desc">Get in touch with our team</div>
            </div>
          </a>
          <a href="/membership" class="quick-card" style="border-color:#ea580c;">
            <div class="quick-icon" style="background:#7c2d12;color:#f97316;" aria-hidden="true">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div>
              <div class="quick-title" style="color:#f97316;">Join Now</div>
              <div class="quick-desc">Start your fitness journey today</div>
            </div>
          </a>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style is:global>
  #quick-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .quick-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .quick-card:hover {
    box-shadow: 0 4px 12px rgba(234,88,12,0.15);
    transform: translateY(-1px);
    border-color: #ea580c;
  }

  .quick-icon {
    display: flex;
    height: 2.5rem;
    width: 2.5rem;
    min-width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: #27272a;
    color: #f97316;
    flex-shrink: 0;
  }

  .quick-icon svg {
    height: 1.25rem;
    width: 1.25rem;
  }

  .quick-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.2rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Fixed: #71717a → #a1a1aa for contrast on dark background */
  .quick-desc {
    font-size: 0.8rem;
    color: #a1a1aa;
    line-height: 1.5;
  }

  .result-card {
    display: block;
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    margin-bottom: 1rem;
  }

  .result-card:hover {
    box-shadow: 0 4px 12px rgba(234,88,12,0.15);
    transform: translateY(-1px);
    border-color: #ea580c;
  }

  .result-excerpt mark {
    background: rgba(234,88,12,0.25);
    color: #fdba74;
    border-radius: 2px;
    padding: 0 2px;
  }

  @media (max-width: 640px) {
    #quick-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  async function runSearch() {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q')?.trim() ?? '';
    const statusEl = document.getElementById('search-status');
    const resultsEl = document.getElementById('search-results-list');
    const quickLinks = document.getElementById('quick-links');
    const heroInput = document.getElementById('hero-search') as HTMLInputElement;

    if (heroInput && query) heroInput.value = query;

    if (!query || !statusEl || !resultsEl || !quickLinks) return;

    resultsEl.style.minHeight = '300px';
    quickLinks.hidden = true;
    statusEl.innerHTML = '<p style="color:#a1a1aa;font-size:0.9rem;">Searching...</p>';
    resultsEl.innerHTML = `
      <div style="display:flex;flex-direction:column;gap:1rem;">
        ${[1,2,3].map(() => `
          <div style="background:#18181b;border:1px solid #27272a;border-radius:0.75rem;padding:1.25rem 1.5rem;">
            <div style="height:1.25rem;background:#27272a;border-radius:0.25rem;width:40%;margin-bottom:0.5rem;"></div>
            <div style="height:0.75rem;background:#27272a;border-radius:0.25rem;width:25%;margin-bottom:0.75rem;"></div>
            <div style="height:0.875rem;background:#27272a;border-radius:0.25rem;width:90%;margin-bottom:0.375rem;"></div>
            <div style="height:0.875rem;background:#27272a;border-radius:0.25rem;width:75%;"></div>
          </div>
        `).join('')}
      </div>
    `;

    let pagefind: any;
    try {
      // @ts-ignore
      pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
    } catch {
      statusEl.innerHTML = '<p style="color:#a1a1aa;font-size:0.9rem;">Search index not available. Try again on the live site.</p>';
      resultsEl.style.minHeight = '0';
      quickLinks.hidden = false;
      return;
    }

    const results = await pagefind.search(query);
    const data = await Promise.all(results.results.map((r: any) => r.data()));

    if (data.length === 0) {
      statusEl.innerHTML = '';
      resultsEl.innerHTML = `
        <div style="text-align:center;padding:3rem 1.5rem;background:#18181b;border:1px solid #27272a;border-radius:0.75rem;margin-bottom:2rem;">
          <span style="font-size:3rem;display:block;margin-bottom:1rem;">🔍</span>
          <h2 style="font-size:1.25rem;font-weight:700;color:white;margin-bottom:0.5rem;text-transform:uppercase;">No results for "${query}"</h2>
          <p style="font-size:0.9rem;color:#a1a1aa;margin-bottom:1.5rem;">Try a different search term or browse the quick links below.</p>
          <!-- Fixed: background #ea580c → #c2410c for WCAG AA contrast -->
          <a href="/classes" style="display:inline-flex;align-items:center;gap:0.5rem;background:#c2410c;color:white;font-weight:700;padding:0.75rem 1.5rem;border-radius:0.5rem;text-decoration:none;font-size:0.9rem;text-transform:uppercase;letter-spacing:0.05em;">View All Classes</a>
        </div>
      `;
      quickLinks.hidden = false;
      return;
    }

    statusEl.innerHTML = `<p style="color:#a1a1aa;font-size:0.9rem;margin-bottom:1.5rem;"><strong style="color:white;">${data.length}</strong> result${data.length === 1 ? '' : 's'} for "<strong style="color:#f97316;">${query}</strong>"</p>`;

    resultsEl.innerHTML = data.map((item: any) => `
      <a href="${item.url}" class="result-card">
        <div style="font-size:1.1rem;font-weight:700;color:#f97316;margin-bottom:0.375rem;text-transform:uppercase;letter-spacing:0.02em;">${item.meta?.title ?? 'Summit Fitness & CrossFit'}</div>
        <div style="font-size:0.75rem;color:#16a34a;margin-bottom:0.5rem;font-weight:500;">pro2.jakefixestech.com${item.url}</div>
        <div style="font-size:0.9rem;color:#a1a1aa;line-height:1.6;">${item.excerpt ?? ''}</div>
      </a>
    `).join('');
  }

  runSearch();
</script>