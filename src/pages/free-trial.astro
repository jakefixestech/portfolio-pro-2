---
import Layout from '../layouts/Layout.astro';

const steps = [
  {
    number: '01',
    title: 'Copy the Code',
    description: 'Click the copy button above to save the promo code to your clipboard.'
  },
  {
    number: '02',
    title: 'Visit the Contact Page',
    description: 'Head to our contact form and paste the code in the message field.'
  },
  {
    number: '03',
    title: 'Show Up & Train',
    description: 'We\'ll reach out to schedule your free class. Just bring yourself and get ready to sweat.'
  }
];

const included = [
  {
    text: 'Full coached CrossFit class',
    description: 'Experience a complete workout guided by our certified coaches'
  },
  {
    text: 'Complete facility access',
    description: 'Use all our equipment, locker rooms, and amenities'
  },
  {
    text: 'Meet the coaches',
    description: 'Get personalized attention and learn about our training philosophy'
  },
  {
    text: 'Zero commitment required',
    description: 'No credit card, no contracts, no pressure — just a great workout'
  }
];
---

<Layout
  title="Free Trial | Summit Fitness & CrossFit"
  description="Claim your free first class at Summit Fitness & CrossFit. No commitment, no credit card required. Just show up and experience world-class CrossFit training."
>
  <!-- Hero Section -->
  <section
    class="relative py-20 md:py-28 lg:py-32 bg-zinc-900"
    aria-labelledby="hero-heading"
  >
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-orange-600/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-600/30 to-transparent"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-600/10 border border-orange-600/30 mb-6">
          <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
          </svg>
          <span class="text-orange-500 font-semibold uppercase tracking-wide text-sm">Limited Time Offer</span>
        </div>

        <h1
          id="hero-heading"
          class="font-display text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-tight mb-6"
        >
          Your First Class Is <span class="text-orange-500">On Us</span>
        </h1>
        <p class="text-lg md:text-xl text-zinc-300 leading-relaxed max-w-2xl mx-auto">
          Ready to experience what real training feels like? We're offering you a
          complimentary full-access class — no strings attached, no sales pitch,
          just pure fitness.
        </p>
      </div>
    </div>
  </section>

  <!-- Promo Code Section -->
  <section
    class="py-16 md:py-24 bg-zinc-950"
    aria-labelledby="promo-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h2
          id="promo-heading"
          class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight mb-4"
        >
          Your Exclusive Promo Code
        </h2>
        <p class="text-zinc-400 mb-8">
          Copy this code and paste it in the message field on our Contact page to claim your free class.
        </p>

        <!-- Promo Code Display Box -->
        <div class="relative bg-zinc-900 rounded-2xl border-2 border-orange-600 p-8 md:p-10 shadow-xl">
          <div class="absolute top-0 left-0 w-6 h-6 border-t-4 border-l-4 border-orange-600 rounded-tl-xl" aria-hidden="true"></div>
          <div class="absolute top-0 right-0 w-6 h-6 border-t-4 border-r-4 border-orange-600 rounded-tr-xl" aria-hidden="true"></div>
          <div class="absolute bottom-0 left-0 w-6 h-6 border-b-4 border-l-4 border-orange-600 rounded-bl-xl" aria-hidden="true"></div>
          <div class="absolute bottom-0 right-0 w-6 h-6 border-b-4 border-r-4 border-orange-600 rounded-br-xl" aria-hidden="true"></div>

          <div class="flex flex-col items-center gap-6">
            <div class="flex items-center gap-4">
              <svg class="w-8 h-8 text-orange-500 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>

              <code
                id="promo-code"
                class="font-mono text-3xl md:text-4xl lg:text-5xl font-bold text-orange-500 tracking-wider select-all"
              >
                SUMMIT-FREE
              </code>

              <svg class="w-8 h-8 text-orange-500 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>

            <button
              type="button"
              id="copy-btn"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange-700 text-white font-bold uppercase tracking-wide rounded transition-all duration-200 hover:bg-orange-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900"
              aria-describedby="copy-hint"
            >
              <svg class="w-5 h-5 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <svg class="w-5 h-5 check-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="btn-text">Copy Code</span>
            </button>

            <p id="copy-hint" class="text-zinc-500 text-sm">
              Click to copy to clipboard
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Steps Section -->
  <section
    class="py-16 md:py-24 bg-zinc-900"
    aria-labelledby="steps-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <div class="flex items-center justify-center gap-4 mb-4">
          <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
          <h2 id="steps-heading" class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">
            How It Works
          </h2>
          <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
        </div>
        <p class="text-zinc-400 max-w-2xl mx-auto">Three simple steps to get started on your fitness journey</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <ol class="grid gap-8 md:grid-cols-3" role="list">
          {steps.map((step) => (
            <li>
              <div class="bg-zinc-950 rounded-xl border border-zinc-800 p-6 text-center hover:border-orange-600/30 transition-colors duration-200 h-full">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-orange-600/10 border-2 border-orange-600 mb-4">
                  <span class="font-display text-2xl font-bold text-orange-500">
                    {step.number}
                  </span>
                </div>
                <h3 class="font-display text-xl font-bold uppercase tracking-tight mb-2">
                  {step.title}
                </h3>
                <p class="text-zinc-400 text-sm leading-relaxed">
                  {step.description}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section
    class="py-16 md:py-24 bg-zinc-950"
    aria-labelledby="included-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
              <h2
                id="included-heading"
                class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight"
              >
                What's <span class="text-orange-500">Included</span>
              </h2>
            </div>
            <p class="text-zinc-400 mb-8">
              Your free trial gives you the full Summit experience. Here's what you'll get:
            </p>

            <ul class="space-y-6" role="list">
              {included.map((item) => (
                <li class="flex gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-orange-600/10 border border-orange-600/30 flex items-center justify-center">
                    <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-display text-lg font-bold uppercase tracking-tight mb-1">
                      {item.text}
                    </h3>
                    <p class="text-zinc-400 text-sm">
                      {item.description}
                    </p>
                  </div>
                </li>
              ))}
            </ul>
          </div>

          <!-- Visual element -->
          <div class="relative" aria-hidden="true">
            <div class="aspect-square rounded-2xl bg-gradient-to-br from-zinc-900 to-zinc-950 border border-zinc-800 flex items-center justify-center overflow-hidden">
              <div class="absolute inset-0 opacity-10">
                <div class="absolute top-1/4 left-1/4 w-32 h-32 border-4 border-orange-600 rounded-full"></div>
                <div class="absolute bottom-1/4 right-1/4 w-24 h-24 border-4 border-orange-600 rounded-full"></div>
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 border-4 border-orange-600 rounded-full"></div>
              </div>
              <div class="relative z-10 flex flex-col items-center">
                <div class="w-32 h-32 rounded-full bg-orange-600/20 border-4 border-orange-600 flex items-center justify-center mb-4">
                  <svg class="w-16 h-16 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
                <span class="font-display text-2xl font-bold uppercase tracking-tight text-orange-500">Free Class</span>
                <span class="text-zinc-500 text-sm">No Commitment</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA Section -->
  <section
    class="py-20 md:py-28 bg-zinc-900 relative overflow-hidden"
    aria-labelledby="cta-heading"
  >
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-orange-600/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-orange-600/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h2
          id="cta-heading"
          class="font-display text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-tight mb-6"
        >
          Ready to <span class="text-orange-500">Claim Your Free Class?</span>
        </h2>
        <p class="text-lg text-zinc-300 mb-8 leading-relaxed">
          Don't wait. Copy the code, fill out our contact form, and we'll get you
          scheduled for your first session. Your transformation starts now.
        </p>

        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-orange-700 text-white text-lg font-bold uppercase tracking-wide rounded transition-all duration-200 hover:bg-orange-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-900"
        >
          <span>Claim Your Free Class</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <p class="mt-6 text-zinc-500 text-sm">
          Code: <code class="text-orange-500 font-mono">SUMMIT-FREE</code> — Valid for new members only
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.getElementById('copy-btn');
    const promoCode = document.getElementById('promo-code');

    if (copyBtn && promoCode) {
      copyBtn.addEventListener('click', async () => {
        const code = promoCode.textContent?.trim() || 'SUMMIT-FREE';

        try {
          await navigator.clipboard.writeText(code);
          const copyIcon = copyBtn.querySelector('.copy-icon');
          const checkIcon = copyBtn.querySelector('.check-icon');
          const btnText = copyBtn.querySelector('.btn-text');

          if (copyIcon && checkIcon && btnText) {
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            btnText.textContent = 'Copied!';
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
              btnText.textContent = 'Copy Code';
            }, 2000);
          }
        } catch (err) {
          const textArea = document.createElement('textarea');
          textArea.value = code;
          textArea.style.position = 'fixed';
          textArea.style.opacity = '0';
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand('copy');
          document.body.removeChild(textArea);
          const btnText = copyBtn.querySelector('.btn-text');
          if (btnText) {
            btnText.textContent = 'Copied!';
            setTimeout(() => { btnText.textContent = 'Copy Code'; }, 2000);
          }
        }
      });
    }
  });
</script>