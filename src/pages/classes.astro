---
import Layout from '../layouts/Layout.astro';

const classes = [
  { name: 'CrossFit', icon: 'dumbbell', difficulty: 'All Levels', duration: '60 min', description: 'Our signature class combining functional movements, strength training, and metabolic conditioning. Scalable for all fitness levels with expert coaching every step of the way.' },
  { name: 'Olympic Weightlifting', icon: 'barbell', difficulty: 'Intermediate', duration: '75 min', description: 'Master the snatch and clean & jerk with focused technique work and progressive loading. Perfect for athletes looking to build explosive power and precision.' },
  { name: 'Open Gym', icon: 'gym', difficulty: 'All Levels', duration: 'Flexible', description: 'Access our full facility to work on your own programming. Coaches are available for form checks and spotting. Ideal for experienced athletes or supplemental training.' },
  { name: 'Endurance & Cardio', icon: 'heart', difficulty: 'Intermediate', duration: '45 min', description: 'High-intensity cardio sessions featuring rowing, biking, running, and bodyweight movements. Build your engine and improve your work capacity.' },
  { name: 'Mobility & Recovery', icon: 'stretch', difficulty: 'Beginner', duration: '45 min', description: 'Focused stretching, foam rolling, and movement therapy to improve flexibility and prevent injury. Essential for long-term athletic performance.' },
  { name: 'Foundations', icon: 'star', difficulty: 'Beginner', duration: '60 min', description: 'Our comprehensive intro program for newcomers. Learn fundamental movements, gym etiquette, and build the foundation for your fitness journey in a supportive environment.' }
];

const steps = [
  { number: '01', title: 'Book Your Free Trial', description: 'Sign up online or give us a call to schedule your complimentary first class. No commitment required.' },
  { number: '02', title: 'Arrive Early', description: 'Come 15 minutes before class to meet your coach, tour the facility, and discuss your fitness goals.' },
  { number: '03', title: 'Join the Workout', description: 'Every movement is scalable. Your coach will guide you through modifications so you get a great workout at your level.' },
  { number: '04', title: 'Become Part of the Community', description: 'Stick around after class to meet fellow members. The Summit community is what makes us special.' }
];

function getDifficultyColor(difficulty: string): string {
  switch (difficulty) {
    case 'Beginner': return 'bg-green-500/20 text-green-400 border-green-500/30';
    case 'Intermediate': return 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30';
    case 'Advanced': return 'bg-red-500/20 text-red-400 border-red-500/30';
    default: return 'bg-orange-600/20 text-orange-400 border-orange-600/30';
  }
}
---

<Layout
  title="Classes | Summit Fitness & CrossFit"
  description="Explore our diverse class offerings including CrossFit, Olympic Weightlifting, Endurance training, and more. Find the perfect class for your fitness level."
>
  <!-- Hero -->
  <section class="relative py-20 md:py-28 bg-zinc-900" aria-labelledby="hero-heading">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-orange-600/10 to-transparent"></div>
      <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-orange-600/30 to-transparent"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl">
        <h1 id="hero-heading" class="font-display text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-tight mb-6">
          Our <span class="text-orange-500">Classes</span>
        </h1>
        <p class="text-lg md:text-xl text-zinc-300 leading-relaxed">
          From high-intensity CrossFit workouts to focused skill sessions, we offer a variety of
          classes designed to challenge you, build community, and deliver results. Every class is
          led by certified coaches who scale movements to your ability.
        </p>
      </div>
    </div>
  </section>

  <!-- Classes Grid -->
  <section class="py-16 md:py-24 bg-zinc-950" aria-labelledby="classes-grid-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <div class="flex items-center justify-center gap-4 mb-4">
          <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
          <h2 id="classes-grid-heading" class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">Find Your Fit</h2>
          <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
        </div>
        <p class="text-zinc-400 max-w-2xl mx-auto">Whether you're a beginner or a seasoned athlete, we have a class that's right for you.</p>
      </div>

      <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" role="list">
        {classes.map((classItem) => (
          <li>
            <article
              class="h-full bg-zinc-900 rounded-lg p-6 md:p-8 border border-zinc-800 transition-all duration-300 hover:border-orange-600/50 hover:shadow-lg flex flex-col"
              aria-labelledby={`class-${classItem.icon}`}
            >
              <div class="mb-5">
                {classItem.icon === 'dumbbell' && (
                  <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12h1m16 0h1m-4 0h-2m-8 0H5m4 0V9m0 6v-3m8-3v3m0 3v-3M7 9a2 2 0 012-2h1a2 2 0 012 2v6a2 2 0 01-2 2H9a2 2 0 01-2-2V9zm8 0a2 2 0 012-2h1a2 2 0 012 2v6a2 2 0 01-2 2h-1a2 2 0 01-2-2V9z" />
                  </svg>
                )}
                {classItem.icon === 'barbell' && (
                  <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h2v8H4V8zm14 0h2v8h-2V8zM8 10h8v4H8v-4zM2 10h2v4H2v-4zm18 0h2v4h-2v-4z" />
                  </svg>
                )}
                {classItem.icon === 'gym' && (
                  <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                )}
                {classItem.icon === 'heart' && (
                  <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                )}
                {classItem.icon === 'stretch' && (
                  <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                )}
                {classItem.icon === 'star' && (
                  <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  </svg>
                )}
              </div>

              <h3 id={`class-${classItem.icon}`} class="font-display text-xl font-bold uppercase tracking-tight mb-3">
                {classItem.name}
              </h3>
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class={`px-3 py-1 text-xs font-semibold uppercase tracking-wide rounded-full border ${getDifficultyColor(classItem.difficulty)}`}>
                  {classItem.difficulty}
                </span>
                <span class="flex items-center gap-1.5 text-sm text-zinc-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {classItem.duration}
                </span>
              </div>

              <p class="text-zinc-400 leading-relaxed flex-1">{classItem.description}</p>
            </article>
          </li>
        ))}
      </ul>

      <!-- Single CTA below the grid -->
      <div class="mt-12 text-center">
        <a
          href="/schedule"
          class="btn-primary text-lg"
        >
          View Full Schedule
        </a>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-16 md:py-24 bg-zinc-900" aria-labelledby="expect-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12 md:mb-16">
          <div class="flex items-center justify-center gap-4 mb-4">
            <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
            <h2 id="expect-heading" class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">What to Expect</h2>
            <div class="w-12 h-1 bg-orange-600" aria-hidden="true"></div>
          </div>
          <p class="text-zinc-400 max-w-2xl mx-auto">New to Summit? Here's what your first visit looks like — no experience necessary.</p>
        </div>

        <ol class="grid gap-6 md:grid-cols-2">
          {steps.map((step) => (
            <li>
              <div class="bg-zinc-950 rounded-lg p-6 border border-zinc-800 h-full">
                <div class="flex items-start gap-4">
                  <span
                    class="flex-shrink-0 w-12 h-12 flex items-center justify-center rounded-full bg-orange-600/10 border-2 border-orange-600 text-orange-500 font-display font-bold text-lg"
                    aria-hidden="true"
                  >
                    {step.number}
                  </span>
                  <div>
                    <h3 class="font-display text-lg font-bold uppercase tracking-tight mb-2">{step.title}</h3>
                    <p class="text-zinc-400 leading-relaxed">{step.description}</p>
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-zinc-950 relative overflow-hidden" aria-labelledby="cta-heading">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-64 h-64 bg-orange-600/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-orange-600/5 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h2 id="cta-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold uppercase tracking-tight mb-6">
          Ready to Get <span class="text-orange-500">Started</span>?
        </h2>
        <p class="text-lg text-zinc-300 mb-8 leading-relaxed">
          Your first class is on us. Book a free trial session and experience the Summit difference.
          No contracts, no pressure — just a chance to see if we're the right fit for you.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/membership" class="btn-primary text-lg">Start Your Free Trial</a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-orange-600 text-orange-500 font-bold uppercase tracking-wide rounded transition-all duration-200 hover:bg-orange-600 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2 focus-visible:ring-offset-zinc-950"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>